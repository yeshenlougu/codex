{
  "name": "codex-desktop",
  "version": "1.0.0",
  "description": "Codex Go - AI Coding Agent with Desktop Pet",
  "main": "main.js",
  "author": "yeshenlougu <codex@yeshenlougu.dev>",
  "homepage": "https://github.com/yeshenlougu/codex",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.codex-go.desktop",
    "productName": "Codex Go",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "pet.html",
      "web-dist/**",
      "!node_modules/**"
    ],
    "extraResources": [
      {
        "from": "codex-go",
        "to": "backend/codex-go"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["portable", "nsis"],
      "sign": null
    },
    "linux": {
      "target": ["AppImage", "deb", "tar.gz"],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
